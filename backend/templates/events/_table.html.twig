<table>
    <thead>
        <tr>
            <th>Date</th>
            <th>Time</th>
            <th>Competition</th>
            <th>Teams</th>
            <th>Result</th>
        </tr>
    </thead>
    <tbody>
        {% for event in events %}
            <tr>
                <td>{{ event.date }}</td>
                <td>{{ event.time }}</td>
                <td>{{ event.competition }}</td>
                <td>{{ event.homeTeam }} - {{ event.awayTeam }}</td>
                <td>{{ event.result ?? '-' }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>